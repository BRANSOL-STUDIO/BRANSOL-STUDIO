# Supabase (required for auth)
# On Vercel: set these in Project → Settings → Environment Variables for Production.
# After adding/changing them, redeploy (NEXT_PUBLIC_* are baked in at build time).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Create 2 dashboard users (run: npm run create-dashboard-users)
# Copy to .env.local and set passwords; do not commit .env.local
DASHBOARD_USER_1_EMAIL=ricardo@bransol.net
DASHBOARD_USER_1_PASSWORD=
DASHBOARD_USER_2_EMAIL=ashleigh@bransol.net
DASHBOARD_USER_2_PASSWORD=

# Site
NEXT_PUBLIC_SITE_URL=https://bransol.co.za
